{
  "printWidth": 100,
  "singleQuote": true,
  "plugins": ["prettier-plugin-organize-attributes", "prettier-plugin-tailwindcss"],
  "attributeGroups": ["^\\*", "^\\(", "^\\[\\(", "^\\[", "^#", "$DEFAULT"],
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "parser": "angular"
      }
    }
  ]
}
